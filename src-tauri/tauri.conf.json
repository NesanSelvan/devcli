{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevCLI",
  "version": "0.3.4",
  "identifier": "dev.devcli.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node node_modules/vite/bin/vite.js",
    "beforeBuildCommand": "node node_modules/vite/bin/vite.js build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevCLI",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/NesanSelvan/devcli/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxODI3NDlEQ0IyM0VENDAKUldSQTdTUExuWFNDNFNJWVZNOUN1dGY1WUNZNmpFdnRTU3lFOHJoVG42bVlzTHhHeHFDMWZnQ28K"
    }
  }
}
