{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevCLI",
  "version": "0.0.0",
  "identifier": "dev.sett.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node node_modules/vite/bin/vite.js",
    "beforeBuildCommand": "node node_modules/vite/bin/vite.js build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevCLI",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
